<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="15dp">

    <TextView
        android:id="@+id/tv_switch"
        style="@style/setUserInfoLabel"
        android:text="血液私人模式" />

    <Switch
        android:id="@+id/switch_open"
        android:layout_toEndOf="@id/tv_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_switch"
        android:layout_marginStart="10dp"
        />




    <TextView
        android:id="@+id/tv_b1"
        style="@style/setUserInfoLabel"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_switch"
        android:text="尿酸" />

    <EditText
        android:id="@+id/et_value1"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b1"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b1"
        android:inputType="number"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b1_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b1"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/et_value1"
        android:text="umol/L"
        android:textColor="#989898" />




    <TextView
        android:id="@+id/tv_b2"
        style="@style/setUserInfoLabel"
        android:layout_below="@+id/tv_b1"
        android:text="总胆固醇" />



    <EditText
        android:id="@+id/et_value2"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b2"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b2"
        android:inputType="numberDecimal"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b2_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b2"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/et_value2"
        android:text="umol/L"
        android:textColor="#989898" />


    <TextView
        android:id="@+id/tv_b3"
        style="@style/setUserInfoLabel"
        android:layout_below="@+id/tv_b2"
        android:text="甘油三酯" />



    <EditText
        android:id="@+id/et_value3"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b3"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b3"
        android:inputType="numberDecimal"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b3_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b3"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/et_value3"
        android:text="umol/L"
        android:textColor="#989898" />


    <TextView
        android:id="@+id/tv_b4"
        style="@style/setUserInfoLabel"
        android:layout_below="@+id/tv_b3"
        android:text="高密度脂蛋白" />

    <EditText
        android:id="@+id/et_value4"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b4"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b4"
        android:inputType="numberDecimal"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b4_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b4"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/et_value4"
        android:text="umol/L"
        android:textColor="#989898" />

    <TextView
        android:id="@+id/tv_b5"
        style="@style/setUserInfoLabel"
        android:layout_below="@+id/tv_b4"
        android:text="低密度脂蛋白" />

    <EditText
        android:id="@+id/et_value5"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b5"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b5"
        android:inputType="numberDecimal"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b5_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b5"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/et_value5"
        android:text="umol/L"
        android:textColor="#989898" />




    <Button
        android:id="@+id/btn_send"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/et_value5"
        android:layout_marginTop="50dp"
        android:text="@string/set"
        android:textAllCaps="false"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_get"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btn_send"
        android:layout_marginTop="20dp"
        android:text="查询"
        android:textAllCaps="false"
        android:textColor="@android:color/white" />
</RelativeLayout>