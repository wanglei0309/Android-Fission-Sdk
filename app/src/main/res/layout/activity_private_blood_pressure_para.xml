<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="15dp">

    <TextView
        android:id="@+id/tv_switch"
        style="@style/setUserInfoLabel"
        android:text="血压私人模式" />

    <Switch
        android:id="@+id/switch_open"
        android:layout_toEndOf="@id/tv_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_switch"
        android:layout_marginStart="10dp"
        />




    <TextView
        android:id="@+id/tv_b1"
        style="@style/setUserInfoLabel"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_switch"
        android:text="血压最高" />

    <EditText
        android:id="@+id/etMaxBp"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b1"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b1"
        android:inputType="number"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b1_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b1"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/etMaxBp"
        android:text="mmHg"
        android:textColor="#989898" />




    <TextView
        android:id="@+id/tv_b2"
        style="@style/setUserInfoLabel"
        android:layout_below="@+id/tv_b1"
        android:text="血压最低" />



    <EditText
        android:id="@+id/etMinBp"
        style="@style/BackgroundEditText"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b2"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/tv_b2"
        android:inputType="number"
        android:maxLength="4" />

    <TextView
        android:id="@+id/tv_b2_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/tv_b2"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/etMaxBp"
        android:text="mmHg"
        android:textColor="#989898" />


    <Button
        android:id="@+id/btn_send"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/etMinBp"
        android:layout_marginTop="50dp"
        android:text="@string/set"
        android:textAllCaps="false"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_get"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btn_send"
        android:layout_marginTop="20dp"
        android:text="查询"
        android:textAllCaps="false"
        android:textColor="@android:color/white" />
</RelativeLayout>